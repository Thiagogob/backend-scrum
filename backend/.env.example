# ============================================================
# Banco de Dados — PostgreSQL (Supabase)
# Settings > Database > Connection parameters
# ============================================================
DB_HOST=db.XXXXXXXXXX.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI

# ============================================================
# Servidor
# ============================================================
PORT=3001

# ============================================================
# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=sua_chave_secreta_longa_e_aleatoria_aqui

# ============================================================
# CORS — URL do frontend (sem barra no final)
# Em produção: URL do deploy do frontend (ex: https://meu-frontend.vercel.app)
# ============================================================
FRONTEND_URL=http://localhost:5173
